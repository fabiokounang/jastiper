<header class="topbar">
  <div class="container topbar-inner">
    <a href="/" class="brand">
      <span class="brand-icon">J</span>
      <span class="brand-copy">
        <strong>Jastip Platform</strong>
        <small>Cozy cross-border shopping</small>
      </span>
    </a>

    <nav class="nav" aria-label="Main navigation">
      <a href="/" class="nav-link <%= currentPath === '/' ? 'active' : '' %>">Home</a>
      <a href="/trip/sample-trip" class="nav-link <%= currentPath.includes('/trip') ? 'active' : '' %>">Trip</a>
      <a href="/cart" class="nav-link <%= currentPath === '/cart' ? 'active' : '' %>">Cart</a>
      <% if (authUser && authUser.role === 'jastiper') { %>
        <a href="/jastiper/dashboard" class="nav-link <%= currentPath.includes('/jastiper') ? 'active' : '' %>">Jastiper</a>
      <% } %>
      <% if (authUser && authUser.role === 'buyer') { %>
        <a href="/buyer/dashboard" class="nav-link <%= currentPath.includes('/buyer') ? 'active' : '' %>">Buyer</a>
      <% } %>
      <% if (authUser && authUser.role === 'admin') { %>
        <a href="/admin/dashboard" class="nav-link <%= currentPath.includes('/admin') ? 'active' : '' %>">Admin</a>
      <% } %>
    </nav>

    <div class="topbar-actions">
      <% if (authUser) { %>
        <span class="role-chip"><%= authUser.role %></span>
        <form action="/logout" method="post">
          <button type="submit" class="btn btn-ghost btn-sm">Logout</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn btn-ghost btn-sm">Login</a>
        <a href="/register" class="btn btn-primary btn-sm">Register</a>
      <% } %>
    </div>
  </div>
</header>
