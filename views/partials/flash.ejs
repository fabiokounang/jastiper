<% if (flash && flash.success && flash.success.length) { %>
  <div class="alert success" role="status" aria-live="polite">
    <strong>Success:</strong> <%= flash.success[0] %>
  </div>
<% } %>
<% if (flash && flash.error && flash.error.length) { %>
  <div class="alert error" role="alert">
    <strong>Error:</strong> <%= flash.error[0] %>
  </div>
<% } %>
