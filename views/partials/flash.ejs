<% if (flash && flash.success && flash.success.length) { %>
  <div class="flash flash-success" role="status" aria-live="polite">
    <span>Success</span>
    <p><%= flash.success[0] %></p>
  </div>
<% } %>
<% if (flash && flash.error && flash.error.length) { %>
  <div class="flash flash-error" role="alert">
    <span>Error</span>
    <p><%= flash.error[0] %></p>
  </div>
<% } %>
