<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          eyebrow: 'Buyer Flow',
          title: 'Checkout',
          subtitle: 'Finalize shipping details and payment preference.',
          actions: [{ label: 'Back to Cart', href: '/cart', variant: 'secondary' }]
        }) %>

        <section class="grid two-col">
          <article class="card cozy stack">
            <h3>Shipping form</h3>
            <p class="muted">
              Receiver name, phone, address, city, postal code, and checkout notes are prepared
              for Stage 4.
            </p>
          </article>

          <article class="card stack">
            <h3>Payment area</h3>
            <p class="muted">
              QRIS/MNC architecture and callback status sync will be connected in Stage 5.
            </p>
          </article>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
