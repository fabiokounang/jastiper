<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          title: 'Checkout',
          subtitle: 'Finalize receiver, shipping, and payment preferences.',
          actions: [{ label: 'Back to Cart', href: '/cart', variant: 'secondary' }]
        }) %>

        <section class="grid two-col">
          <article class="card cozy">
