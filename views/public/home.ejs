<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/flash') %>

        <section class="hero-grid">
          <article class="card cozy stack">
            <span class="badge">One platform, three roles</span>
            <h1>Modern jastip experience that feels clear and comfortable</h1>
            <p class="muted">
              Built for jastiper, buyer, and admin in one application. Share trip links, receive
              orders, and track progress with a cleaner flow.
            </p>
            <div class="hero-actions">
              <a class="btn btn-primary" href="/register">Get Started</a>
              <a class="btn btn-ghost" href="/login">I have account</a>
            </div>
          </article>

          <article class="card subtle stack">
            <h3>Platform highlights</h3>
            <div class="stats-grid two-col">
              <article class="card kpi-card">
                <p class="kpi">3</p>
                <span>Role dashboards</span>
              </article>
              <article class="card kpi-card">
                <p class="kpi">1</p>
                <span>Unified codebase</span>
              </article>
              <article class="card kpi-card">
                <p class="kpi">KTP</p>
                <span>Verification-ready</span>
              </article>
              <article class="card kpi-card">
                <p class="kpi">Live</p>
                <span>Trip share structure</span>
              </article>
            </div>
          </article>
        </section>

        <section class="grid two-col section-gap">
          <article class="card stack">
            <h3>Jastiper workflow</h3>
            <p class="muted">
              Create trips, publish products, and manage order lifecycle from draft to completion.
            </p>
          </article>
          <article class="card stack">
            <h3>Buyer workflow</h3>
            <p class="muted">
              Browse public trip links, add items to cart, checkout quickly, and track payment.
            </p>
          </article>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
