<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/flash') %>

        <section class="hero-panel card cozy">
          <div>
            <span class="pill">Trusted Multi-Role Platform</span>
            <h1>Make your jastip business feel premium, clear, and effortless</h1>
            <p>
              One modern application for jastiper, buyer, and admin operations. Share trips,
              collect orders, and monitor progress with a cleaner experience.
            </p>
            <div class="hero-actions">
              <a class="btn btn-primary" href="/register">Create Account</a>
              <a class="btn btn-secondary" href="/login">Login</a>
            </div>
          </div>

          <div class="card subtle hero-stats">
            <h3>Quick Snapshot</h3>
            <div class="stats-grid two-col compact">
              <article>
                <p class="kpi">3</p>
                <span>Connected roles</span>
              </article>
              <article>
                <p class="kpi">1</p>
                <span>Unified codebase</span>
              </article>
              <article>
                <p class="kpi">100%</p>
                <span>KTP-based onboarding</span>
              </article>
              <article>
                <p class="kpi">Ready</p>
                <span>Checkout + payment flow</span>
              </article>
            </div>
          </div>
        </section>

        <section class="grid two-col section-gap">
          <article class="card">
            <h3>For Jastiper</h3>
            <p>
              Create trips, add products, publish links to social media, and manage order status
              in one dashboard.
            </p>
          </article>
          <article class="card">
            <h3>For Buyer</h3>
            <p>
              Discover products from trip links, checkout quickly, and track payment and delivery
              updates.
            </p>
          </article>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
