<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>
    <main class="page-shell">
      <div class="container">
        <%- include('../partials/flash') %>
        <section class="hero-panel card cozy">
          <div>
            <span class="pill">One App, Multi Role</span>
            <h1>Build and run your jastip business effortlessly</h1>
            <p>
              A modern platform for jastipers, buyers, and admins in one cozy and secure
              ecosystem.
            </p>
            <div class="hero-actions">
              <a class="btn btn-primary" href="/register">Start Now</a>
              <a class="btn btn-secondary" href="/login">I Already Have Account</a>
            </div>
          </div>
          <div class="card subtle hero-stats">
            <h3>Platform Highlights</h3>
            <div class="stats-grid two-col compact">
              <article>
                <p class="kpi">3 Roles</p>
                <span>Admin, Jastiper, Buyer</span>
              </article>
              <article>
                <p class="kpi">1 Codebase</p>
                <span>Single project architecture</span>
              </article>
              <article>
                <p class="kpi">KTP Flow</p>
                <span>Identity verification ready</span>
              </article>
              <article>
                <p class="kpi">Checkout</p>
                <span>Order and payment-ready structure</span>
              </article>
            </div>
          </div>
        </section>

        <section class="section-gap">
          <div class="grid two-col">
            <article class="card">
              <h3>For Jastiper</h3>
              <p>Create trips, add products, publish shareable links to social media.</p>
            </article>
            <article class="card">
              <h3>For Buyer</h3>
              <p>Browse trips, add items to cart, checkout quickly with clear steps.</p>
            </article>
          </div>
        </section>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>
