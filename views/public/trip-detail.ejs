<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          eyebrow: 'Public View',
          title: 'Trip Page',
          subtitle: 'Public buyer-friendly overview with no login required.',
          actions: [{ label: 'Back Home', href: '/', variant: 'secondary' }]
        }) %>

        <section class="grid two-col">
          <article class="card cozy stack">
            <h3>Trip slug</h3>
            <p class="mono">/<%= slug %></p>
            <p class="muted">
              Stage 4 will display destination details, deadline, and published product list.
            </p>
          </article>

          <article class="card stack">
            <h3>Buyer journey</h3>
            <ul class="list-clean">
              <li>Read trip information and notes</li>
              <li>Open product details</li>
              <li>Add to cart and continue checkout</li>
            </ul>
          </article>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
