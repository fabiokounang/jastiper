<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>
    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          title: 'Trip Showcase',
          subtitle: 'Public trip page where buyers explore listed products.',
          actions: [{ label: 'Back Home', href: '/', variant: 'secondary' }]
        }) %>

        <section class="grid two-col">
          <article class="card">
            <h3>Trip Slug</h3>
            <p class="mono">/<%= slug %></p>
            <p>
              Stage 4 will render destination details, timeline, and published products from
              MySQL.
            </p>
          </article>
          <article class="card subtle">
            <h3>Buyer Journey</h3>
            <ul class="list-clean">
              <li>View trip information</li>
              <li>Browse products and variants</li>
              <li>Add to cart and proceed to checkout</li>
            </ul>
          </article>
        </section>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>
