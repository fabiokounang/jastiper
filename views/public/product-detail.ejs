<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>
    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          title: 'Product Detail',
          subtitle: 'Public buyer-facing product page within a trip.',
          actions: [{ label: 'Back to Trip', href: '/trip/' + slug, variant: 'secondary' }]
        }) %>

        <section class="grid two-col">
          <article class="card">
            <h3>Trip</h3>
            <p class="mono"><%= slug %></p>
            <h3>Product</h3>
            <p class="mono"><%= productSlug %></p>
            <p>Stage 4 will show image gallery, variant selectors, and order actions.</p>
          </article>
          <article class="card subtle">
            <h3>Planned Details</h3>
            <ul class="list-clean">
              <li>Price breakdown (base + jastip fee)</li>
              <li>Variant and stock status</li>
              <li>Purchase location and notes</li>
            </ul>
          </article>
        </section>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>
