<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          eyebrow: 'Public View',
          title: product.name,
          subtitle: 'Buyer-friendly detail page with transparent pricing and notes.',
          actions: [{ label: 'Back to Trip', href: '/trip/' + slug, variant: 'secondary' }]
        }) %>
        <%- include('../partials/flash') %>

        <section class="grid two-col">
          <article class="card cozy stack">
            <% if (product.primary_image) { %>
              <img
                src="<%= product.primary_image %>"
                alt="<%= product.name %>"
                style="width:100%; border-radius:12px; border:1px solid #dce4f1"
              />
            <% } %>
            <h3><%= product.name %></h3>
            <p class="muted"><%= product.description || 'No product description yet.' %></p>
            <div class="stack">
              <p><strong>Estimated price:</strong> <%= product.currency %> <%= Number(product.final_price_estimate || 0).toLocaleString('id-ID') %></p>
              <p><strong>Base + fee:</strong> <%= product.currency %> <%= Number(product.base_price || 0).toLocaleString('id-ID') %> + <%= Number(product.jastip_fee || 0).toLocaleString('id-ID') %></p>
              <p><strong>Stock:</strong> <%= Number(product.stock || 0) %></p>
              <p><strong>Status:</strong> <%= product.product_status %></p>
            </div>
            <% if (product.product_status !== 'sold_out' && Number(product.stock || 0) > 0) { %>
              <form action="/cart/add" method="post" class="form-grid">
                <input type="hidden" name="trip_id" value="<%= trip.id %>" />
                <input type="hidden" name="product_id" value="<%= product.id %>" />
                <div>
                  <label for="quantity">Quantity</label>
                  <input id="quantity" name="quantity" type="number" min="1" max="20" value="1" required />
                </div>
                <div>
                  <label for="note">Note (optional)</label>
                  <input id="note" name="note" type="text" maxlength="255" />
                </div>
                <button class="btn btn-primary" type="submit">Add to Cart</button>
              </form>
            <% } else { %>
              <div class="flash flash-error" role="alert">
                <span>Unavailable</span>
                <p>This product is currently sold out or out of stock.</p>
              </div>
            <% } %>
          </article>

          <article class="card stack">
            <h3>Product details</h3>
            <ul class="list-clean">
              <li><strong>Trip:</strong> <%= trip.title %></li>
              <li><strong>Category:</strong> <%= product.category || '-' %></li>
              <li><strong>Brand:</strong> <%= product.brand || '-' %></li>
              <li><strong>Availability:</strong> <%= product.availability_status %></li>
              <li><strong>Preorder:</strong> <%= product.preorder_type || '-' %></li>
              <li><strong>Purchase location:</strong> <%= product.purchase_location || '-' %></li>
            </ul>
            <% if (images && images.length > 1) { %>
              <div class="grid two-col">
                <% images.forEach((image) => { %>
                  <img
                    src="<%= image.image_path %>"
                    alt="Product image"
                    style="width:100%; border-radius:10px; border:1px solid #dce4f1"
                  />
                <% }) %>
              </div>
            <% } %>
            <p class="muted">
              Guest-first checkout stays enabled. Buyer account can be created optionally after payment.
            </p>
          </article>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
