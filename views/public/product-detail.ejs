<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          eyebrow: 'Public View',
          title: 'Product Detail',
          subtitle: 'Simple and readable product context for buyers (no login needed).',
          actions: [{ label: 'Back to Trip', href: '/trip/' + slug, variant: 'secondary' }]
        }) %>

        <section class="grid two-col">
          <article class="card cozy stack">
            <h3>Trip</h3>
            <p class="mono"><%= slug %></p>
            <h3>Product</h3>
            <p class="mono"><%= productSlug %></p>
            <p class="muted">
              Stage 4 will add gallery, variants, pricing estimate, and add-to-cart action.
            </p>
            <p class="muted">Checkout remains guest-friendly and will only ask shipping/payment info.</p>
          </article>

          <article class="card stack">
            <h3>Planned information</h3>
            <ul class="list-clean">
              <li>Base price + jastip fee</li>
              <li>Variant and stock</li>
              <li>Purchase location notes</li>
            </ul>
          </article>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
