<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <main class="page-shell">
      <div class="container small">
        <section class="card soft center error-card">
          <p class="error-code">403</p>
          <h1>Access denied</h1>
