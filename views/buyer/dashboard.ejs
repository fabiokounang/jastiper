<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          title: 'Buyer Dashboard',
          subtitle: 'Track orders, pending payments, and completed transactions with clarity.',
          actions: [
            { label: 'Explore Trips', href: '/', variant: 'primary' },
            { label: 'Order History', href: '/buyer/orders', variant: 'secondary' }
          ]
        }) %>

        <section class="stats-grid three-col">
          <article class="card kpi-card"><p class="kpi">0</p><span>Active Orders</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Pending Payments</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Completed Orders</span></article>
        </section>

        <section class="card cozy section-gap">
          <h3>Stage 4 Focus</h3>
          <p>Live order timeline, payment details, and delivery tracking will appear here.</p>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
