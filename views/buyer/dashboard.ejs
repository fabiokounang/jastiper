<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          eyebrow: 'Buyer',
          title: 'Dashboard',
          subtitle: 'Track your order status and pending payment activities.',
          actions: [
            { label: 'Explore Trips', href: '/', variant: 'primary' },
            { label: 'Order History', href: '/buyer/orders', variant: 'secondary' }
          ]
        }) %>

        <section class="stats-grid three-col">
          <article class="card kpi-card"><p class="kpi">0</p><span>Active Orders</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Pending Payments</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Completed Orders</span></article>
        </section>

        <section class="card soft section-gap">
          <h3>Stage 4 integration</h3>
          <p class="muted">Order timeline and payment status updates will be displayed here.</p>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
