<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <div class="auth-shell">
      <section class="auth-left">
        <a href="/" class="brand">
          <span class="brand-icon">J</span>
          <span class="brand-copy">
            <strong>Jastip Platform</strong>
            <small>Verified registration flow</small>
          </span>
        </a>
        <h1>Create your account</h1>
        <p class="muted">
          Register as buyer or jastiper using KTP information to keep platform trusted.
        </p>
      </section>

      <section class="auth-right">
        <div class="card soft auth-card stack">
          <h2>Register</h2>
          <%- include('../partials/flash') %>

          <form action="/register" method="post" enctype="multipart/form-data" class="form-grid two-col">
            <div class="span-2">
              <label for="full_name">Full Name</label>
              <input id="full_name" type="text" name="full_name" required />
            </div>

            <div>
              <label for="email">Email</label>
              <input id="email" type="email" name="email" required />
            </div>
            <div>
              <label for="phone">Phone</label>
              <input id="phone" type="text" name="phone" required />
            </div>

            <div>
              <label for="password">Password</label>
              <input id="password" type="password" name="password" required />
            </div>
            <div>
              <label for="confirm_password">Confirm Password</label>
              <input id="confirm_password" type="password" name="confirm_password" required />
            </div>

            <div>
              <label for="role">Role</label>
              <select id="role" name="role" required>
                <option value="buyer">Buyer</option>
                <option value="jastiper">Jastiper</option>
              </select>
            </div>
            <div>
              <label for="ktp_number">KTP Number</label>
              <input id="ktp_number" type="text" name="ktp_number" required />
            </div>

            <div class="span-2">
              <label for="ktp_photo">KTP Photo</label>
              <input id="ktp_photo" type="file" name="ktp_photo" accept="image/*" required />
            </div>

            <button type="submit" class="btn btn-primary full span-2">Create account</button>
          </form>

          <p class="muted center">Already registered? <a href="/login">Back to login</a></p>
        </div>
      </section>
    </div>
  </body>
</html>
