<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/flash') %>
        <%- include('../partials/page-header', {
          eyebrow: 'Jastiper Product',
          title: 'Edit Product',
          subtitle: 'Update details, pricing, and publish state.',
          actions: [{ label: 'Back', href: '/jastiper/trips/' + product.trip_id + '/products', variant: 'secondary' }]
        }) %>

        <% if (formError) { %>
          <div class="flash flash-error" role="alert">
            <span>Error</span>
            <p><%= formError %></p>
          </div>
        <% } %>

        <section class="card stack">
          <form method="post" action="/jastiper/products/<%= product.id %>?_method=PUT" enctype="multipart/form-data" class="form-grid two-col">
            <div>
              <label for="trip_id">Trip</label>
              <select id="trip_id" name="trip_id" required>
                <% trips.forEach((trip) => { %>
                  <option value="<%= trip.id %>" <%= Number(product.trip_id) === Number(trip.id) ? 'selected' : '' %>>
                    <%= trip.title %> (<%= trip.status %>)
                  </option>
                <% }) %>
              </select>
            </div>
            <div>
              <label for="name">Product Name</label>
              <input id="name" name="name" type="text" value="<%= product.name %>" required />
            </div>

            <div>
              <label for="slug">Product Slug</label>
              <input id="slug" name="slug" type="text" value="<%= product.slug %>" />
            </div>
            <div>
              <label for="sku">SKU</label>
              <input id="sku" name="sku" type="text" value="<%= product.sku || '' %>" />
            </div>

            <div>
              <label for="category">Category</label>
              <input id="category" name="category" type="text" value="<%= product.category || '' %>" />
            </div>
            <div>
              <label for="brand">Brand</label>
              <input id="brand" name="brand" type="text" value="<%= product.brand || '' %>" />
            </div>

            <div>
              <label for="base_price">Base Price</label>
              <input id="base_price" name="base_price" type="number" step="0.01" min="0" value="<%= product.base_price %>" required />
            </div>
            <div>
              <label for="jastip_fee">Jastip Fee</label>
              <input id="jastip_fee" name="jastip_fee" type="number" step="0.01" min="0" value="<%= product.jastip_fee %>" />
            </div>

            <div>
              <label for="final_price_estimate">Final Price Estimate</label>
              <input id="final_price_estimate" name="final_price_estimate" type="number" step="0.01" min="0" value="<%= product.final_price_estimate %>" required />
            </div>
            <div>
              <label for="currency">Currency</label>
              <input id="currency" name="currency" type="text" maxlength="10" value="<%= product.currency || 'IDR' %>" />
            </div>

            <div>
              <label for="stock">Stock</label>
              <input id="stock" name="stock" type="number" min="0" value="<%= product.stock %>" />
            </div>
            <div>
              <label for="weight">Weight (grams)</label>
              <input id="weight" name="weight" type="number" step="0.01" min="0" value="<%= product.weight || '' %>" />
            </div>

            <div>
              <label for="purchase_location">Purchase Location</label>
              <input id="purchase_location" name="purchase_location" type="text" value="<%= product.purchase_location || '' %>" />
            </div>
            <div>
              <label for="preorder_type">Preorder Type</label>
              <input id="preorder_type" name="preorder_type" type="text" value="<%= product.preorder_type || '' %>" />
            </div>

            <div>
              <label for="availability_status">Availability</label>
              <select id="availability_status" name="availability_status">
                <option value="available" <%= product.availability_status === 'available' ? 'selected' : '' %>>Available</option>
                <option value="limited" <%= product.availability_status === 'limited' ? 'selected' : '' %>>Limited</option>
                <option value="preorder" <%= product.availability_status === 'preorder' ? 'selected' : '' %>>Preorder</option>
                <option value="sold_out" <%= product.availability_status === 'sold_out' ? 'selected' : '' %>>Sold Out</option>
              </select>
            </div>
            <div>
              <label for="product_status">Product Status</label>
              <select id="product_status" name="product_status">
                <option value="draft" <%= product.product_status === 'draft' ? 'selected' : '' %>>Draft</option>
                <option value="published" <%= product.product_status === 'published' ? 'selected' : '' %>>Published</option>
                <option value="hidden" <%= product.product_status === 'hidden' ? 'selected' : '' %>>Hidden</option>
                <option value="sold_out" <%= product.product_status === 'sold_out' ? 'selected' : '' %>>Sold Out</option>
              </select>
            </div>

            <div class="span-2">
              <label for="description">Description</label>
              <textarea id="description" name="description" rows="4"><%= product.description || '' %></textarea>
            </div>

            <div class="span-2">
              <label for="notes">Notes</label>
              <textarea id="notes" name="notes" rows="3"><%= product.notes || '' %></textarea>
            </div>

            <div class="span-2">
              <label for="tags">Tags (comma separated)</label>
              <input id="tags" name="tags" type="text" value="<%= product.tags || '' %>" />
            </div>

            <div class="span-2">
              <label for="product_image">Add New Product Image (optional)</label>
              <input id="product_image" name="product_image" type="file" accept="image/jpeg,image/png,image/webp" />
            </div>

            <div class="span-2 actions">
              <button class="btn btn-primary" type="submit">Save Changes</button>
              <a class="btn btn-ghost" href="/jastiper/trips/<%= product.trip_id %>/products">Cancel</a>
            </div>
          </form>
        </section>

        <% if (images && images.length) { %>
          <section class="card section-gap stack">
            <h3>Product Images</h3>
            <div class="stats-grid three-col">
              <% images.forEach((img) => { %>
                <article class="card subtle stack">
                  <img src="<%= img.image_path %>" alt="Product image" style="width:100%; border-radius:10px; border:1px solid #dce4f1;" />
                  <p class="muted"><%= img.is_primary ? 'Primary image' : 'Additional image' %></p>
                </article>
              <% }) %>
            </div>
          </section>
        <% } %>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
