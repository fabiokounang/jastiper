<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          eyebrow: 'Jastiper',
          title: 'Profile',
          subtitle: 'Manage your shop identity and payout profile details.',
          actions: [{ label: 'Back to Dashboard', href: '/jastiper/dashboard', variant: 'secondary' }]
        }) %>

        <section class="grid two-col">
          <article class="card soft stack">
            <h3>Shop profile</h3>
            <p class="muted">Shop name, bio, Instagram link, and profile photo settings.</p>
          </article>
          <article class="card stack">
            <h3>Bank details</h3>
            <p class="muted">Optional payout data for future disbursement process.</p>
          </article>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
