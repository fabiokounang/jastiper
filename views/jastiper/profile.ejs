<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>
    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          title: 'Jastiper Profile',
          subtitle: 'Edit your shop identity, social links, and contact details.',
          actions: [{ label: 'Back to Dashboard', href: '/jastiper/dashboard', variant: 'secondary' }]
        }) %>

        <section class="grid two-col">
          <article class="card">
            <h3>Shop Information</h3>
            <p>Shop name, bio, Instagram username, and profile photo.</p>
          </article>
          <article class="card subtle">
            <h3>Bank Details</h3>
            <p>Optional payout account information for payment disbursement.</p>
          </article>
        </section>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>
