<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          title: 'Jastiper Dashboard',
          subtitle: 'Manage trips, products, and order updates from a single cozy workspace.',
          actions: [
            { label: 'Create Trip', href: '/jastiper/trips/create', variant: 'primary' },
            { label: 'Orders', href: '/jastiper/orders', variant: 'secondary' }
          ]
        }) %>

        <section class="stats-grid four-col">
          <article class="card kpi-card"><p class="kpi">0</p><span>Draft Trips</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Published Trips</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Products</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Active Orders</span></article>
        </section>

        <section class="card cozy section-gap">
          <h3>Next Build: Stage 3</h3>
          <p>Trip CRUD, product CRUD, and order status timeline will be activated here.</p>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
