<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/flash') %>
        <%- include('../partials/page-header', {
          eyebrow: 'Jastiper',
          title: 'Create Product',
          subtitle: 'Add a product under one of your trips.',
          actions: [{ label: 'Back to Trips', href: '/jastiper/trips', variant: 'secondary' }]
        }) %>

        <% if (formError) { %>
          <div class="flash flash-error" role="alert">
            <span>Error</span>
            <p><%= formError %></p>
          </div>
        <% } %>

        <section class="card soft">
          <form
            action="/jastiper/products"
            method="post"
            enctype="multipart/form-data"
            class="form-grid two-col"
          >
            <div class="span-2">
              <label for="trip_id">Trip</label>
              <select id="trip_id" name="trip_id" required>
                <option value="">Select trip</option>
                <% trips.forEach((trip) => { %>
                  <option value="<%= trip.id %>" <%= Number(old.trip_id) === trip.id ? 'selected' : '' %>>
                    <%= trip.title %> (<%= trip.destination_city %>, <%= trip.destination_country %>)
                  </option>
                <% }) %>
              </select>
            </div>

            <div>
              <label for="name">Product Name</label>
              <input id="name" name="name" type="text" value="<%= old.name %>" required />
            </div>
            <div>
              <label for="slug">Slug (optional)</label>
              <input id="slug" name="slug" type="text" value="<%= old.slug %>" />
            </div>
            <div>
              <label for="category">Category</label>
              <input id="category" name="category" type="text" value="<%= old.category %>" />
            </div>
            <div>
              <label for="brand">Brand</label>
              <input id="brand" name="brand" type="text" value="<%= old.brand %>" />
            </div>
            <div>
              <label for="sku">SKU</label>
              <input id="sku" name="sku" type="text" value="<%= old.sku %>" />
            </div>
            <div>
              <label for="currency">Currency</label>
              <input id="currency" name="currency" type="text" value="<%= old.currency %>" />
            </div>
            <div>
              <label for="base_price">Base Price</label>
              <input
                id="base_price"
                name="base_price"
                type="number"
                min="0"
                step="0.01"
                value="<%= old.base_price %>"
                required
              />
            </div>
            <div>
              <label for="jastip_fee">Jastip Fee</label>
              <input
                id="jastip_fee"
                name="jastip_fee"
                type="number"
                min="0"
                step="0.01"
                value="<%= old.jastip_fee %>"
              />
            </div>
            <div>
              <label for="final_price_estimate">Final Price Estimate</label>
              <input
                id="final_price_estimate"
                name="final_price_estimate"
                type="number"
                min="0"
                step="0.01"
                value="<%= old.final_price_estimate %>"
                required
              />
            </div>
            <div>
              <label for="stock">Stock</label>
              <input id="stock" name="stock" type="number" min="0" step="1" value="<%= old.stock %>" />
            </div>
            <div>
              <label for="weight">Weight (gram)</label>
              <input
                id="weight"
                name="weight"
                type="number"
                min="0"
                step="0.01"
                value="<%= old.weight %>"
              />
            </div>
            <div>
              <label for="purchase_location">Purchase Location</label>
              <input
                id="purchase_location"
                name="purchase_location"
                type="text"
                value="<%= old.purchase_location %>"
              />
            </div>
            <div>
              <label for="preorder_type">Preorder Type</label>
              <input id="preorder_type" name="preorder_type" type="text" value="<%= old.preorder_type %>" />
            </div>
            <div>
              <label for="availability_status">Availability</label>
              <select id="availability_status" name="availability_status">
                <% ['available', 'limited', 'preorder', 'sold_out'].forEach((status) => { %>
                  <option value="<%= status %>" <%= old.availability_status === status ? 'selected' : '' %>>
                    <%= status %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div>
              <label for="product_status">Product Status</label>
              <select id="product_status" name="product_status">
                <% ['draft', 'published', 'hidden', 'sold_out'].forEach((status) => { %>
                  <option value="<%= status %>" <%= old.product_status === status ? 'selected' : '' %>>
                    <%= status %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="span-2">
              <label for="tags">Tags (comma separated)</label>
              <input id="tags" name="tags" type="text" value="<%= old.tags %>" />
            </div>
            <div class="span-2">
              <label for="description">Description</label>
              <textarea id="description" name="description" rows="4"><%= old.description %></textarea>
            </div>
            <div class="span-2">
              <label for="notes">Notes</label>
              <textarea id="notes" name="notes" rows="3"><%= old.notes %></textarea>
            </div>
            <div class="span-2">
              <label for="product_image">Primary Product Image (optional)</label>
              <input id="product_image" name="product_image" type="file" accept="image/*" />
            </div>

            <div class="span-2 actions">
              <button class="btn btn-primary" type="submit">Save Product</button>
              <a href="/jastiper/trips" class="btn btn-ghost">Cancel</a>
            </div>
          </form>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
