<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          title: 'Admin Dashboard',
          subtitle: 'Observe platform health, business metrics, and risk signals in one screen.',
          actions: [
            { label: 'User Monitoring', href: '/admin/users', variant: 'primary' },
            { label: 'Reports', href: '/admin/reports', variant: 'secondary' }
          ]
        }) %>

        <section class="stats-grid four-col">
          <article class="card kpi-card"><p class="kpi">0</p><span>Total Users</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Total Trips</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Total Orders</span></article>
          <article class="card kpi-card"><p class="kpi">0</p><span>Total GMV</span></article>
        </section>

        <section class="card cozy section-gap">
          <h3>Stage 6 Monitoring Map</h3>
          <p>
            Verification queue, top destinations, payment success rate, and moderation actions
            will be connected to this dashboard.
          </p>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
