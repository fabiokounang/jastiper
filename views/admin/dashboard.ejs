<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          eyebrow: 'Admin',
          title: 'Dashboard',
          subtitle: 'Platform overview for users, trips, products, orders, and payments.',
          actions: [
            { label: 'Manage Users', href: '/admin/users', variant: 'primary' },
            { label: 'Reports', href: '/admin/reports', variant: 'secondary' }
          ]
