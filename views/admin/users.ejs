<!DOCTYPE html>
<html lang="en">
  <%- include('../partials/head', { title }) %>
  <body>
    <%- include('../partials/header') %>

    <main class="page-shell">
      <div class="container">
        <%- include('../partials/page-header', {
          eyebrow: 'Admin',
          title: 'User Monitoring',
          subtitle: 'Search and moderate account status in one easy interface.',
          actions: [{ label: 'Back to Dashboard', href: '/admin/dashboard', variant: 'secondary' }]
        }) %>

        <section class="card soft">
          <div class="toolbar">
            <input type="text" placeholder="Search name, email, phone" />
            <select>
              <option>All Roles</option>
              <option>Admin</option>
              <option>Jastiper</option>
              <option>Buyer</option>
            </select>
            <select>
              <option>All Status</option>
              <option>Active</option>
              <option>Suspended</option>
              <option>Pending</option>
            </select>
          </div>

          <div class="empty-state">
            <h3>User table will be active in Stage 6</h3>
            <p>
              This area will contain verification approval/rejection, suspend/activate actions,
              and detailed user profile review.
            </p>
          </div>
        </section>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
